{
  "entities": {
    "Estimate": {
      "title": "Estimate",
      "description": "A consolidated client estimate or order.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "siteAddress": { "type": "string" },
        "architectName": { "type": "string" },
        "assignee": { "type": "string" },
        "version": { "type": "integer" },
        "estimateStatus": { "type": "string" },
        "paymentMode": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "amountPaid": { "type": "number" },
        "balanceAmount": { "type": "number" },
        "grandTotal": { "type": "number" },
        "subtotal": { "type": "number" },
        "totalBoxes": { "type": "number" },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tileName": { "type": "string" },
              "length": { "type": "number" },
              "width": { "type": "number" },
              "unit": { "type": "string", "enum": ["ft", "inch"] },
              "tilesPerBox": { "type": "number" },
              "pricePerSqFt": { "type": "number" },
              "sqFtRequired": { "type": "number" },
              "sqFtPerBox": { "type": "number" },
              "totalBoxes": { "type": "number" },
              "totalPrice": { "type": "number" }
            }
          }
        },
        "remarks": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "expectedDeliveryDate": { "type": "string", "format": "date-time" },
        "deliveryStatus": { "type": "string" },
        "isFinalOrder": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["clientName", "phoneNumber", "assignee", "version", "estimateStatus", "products"]
    }
  },
  "firestore": {
    "estimates": {
      "schema": "Estimate",
      "description": "Collection of consolidated client estimates and orders."
    }
  }
}
