{
  "entities": {
    "Estimate": {
      "title": "Estimate",
      "description": "A consolidated client estimate or order.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "siteAddress": { "type": "string" },
        "architectName": { "type": "string" },
        "assignee": { "type": "string" },
        "version": { "type": "integer" },
        "estimateStatus": { "type": "string" },
        "paymentMode": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "amountPaid": { "type": "number" },
        "balanceAmount": { "type": "number" },
        "grandTotal": { "type": "number" },
        "subtotal": { "type": "number" },
        "totalBoxes": { "type": "number" },
        "tileTotal": { "type": "number" },
        "graniteTotal": { "type": "number" },
        "productTotal": { "type": "number" },
        "cartageAmount": { "type": "number" },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["tile", "quartz", "granite", "product"] },
              "name": { "type": "string" },
              "tileSize": { "type": "string", "description": "Deprecated: use length/width/unit instead" },
              "length": { "type": "number" },
              "width": { "type": "number" },
              "unit": { "type": "string", "enum": ["Feet", "Inches"] },
              "tileAreaSqFt": { "type": "number" },
              "pricePerSqFt": { "type": "number" },
              "discountPerSqFt": { "type": "number" },
              "sqFtRequired": { "type": "number" },
              "sqFtPerBox": { "type": "number" },
              "totalBoxes": { "type": "number" },
              "totalSqFt": { "type": "number" },
              "gstApplied": { "type": "boolean" },
              "gstAmount": { "type": "number" },
              "pieces": { "type": "number" },
              "pricePerPiece": { "type": "number" },
              "totalPrice": { "type": "number" }
            }
          }
        },
        "remarks": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "expectedDeliveryDate": { "type": "string", "format": "date-time" },
        "deliveryStatus": { "type": "string" },
        "isFinalOrder": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["version", "estimateStatus", "products"]
    }
  },
  "firestore": {
    "estimates": {
      "schema": "Estimate",
      "description": "Collection of consolidated client estimates and orders."
    }
  }
}
