{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A client lead representing a project.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "siteAddress": { "type": "string" },
        "architectName": { "type": "string" },
        "assignee": { "type": "string" },
        "remarks": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "activities": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "message": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" },
              "userName": { "type": "string" },
              "userId": { "type": "string" }
            }
          }
        }
      },
      "required": ["clientName", "phoneNumber", "assignee"]
    },
    "Estimate": {
      "title": "Estimate",
      "description": "An individual quotation or order linked to a lead.",
      "type": "object",
      "properties": {
        "leadId": { "type": "string" },
        "version": { "type": "integer" },
        "estimateStatus": { "type": "string" },
        "paymentMode": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "amountPaid": { "type": "number" },
        "balanceAmount": { "type": "number" },
        "grandTotal": { "type": "number" },
        "subtotal": { "type": "number" },
        "totalBoxes": { "type": "number" },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tileName": { "type": "string" },
              "tileSize": { "type": "string" },
              "pricePerSqFt": { "type": "number" },
              "sqFtRequired": { "type": "number" },
              "sqFtPerBox": { "type": "number" },
              "totalBoxes": { "type": "number" },
              "totalPrice": { "type": "number" }
            }
          }
        },
        "remarks": { "type": "string" },
        "orderDate": { "type": "string", "format": "date-time" },
        "expectedDeliveryDate": { "type": "string", "format": "date-time" },
        "deliveryStatus": { "type": "string" },
        "isFinalOrder": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["leadId", "version", "estimateStatus", "products"]
    }
  },
  "firestore": {
    "leads": {
      "schema": "Lead",
      "description": "Collection of client leads."
    },
    "estimates": {
      "schema": "Estimate",
      "description": "Collection of estimates and orders linked to leads."
    }
  }
}
