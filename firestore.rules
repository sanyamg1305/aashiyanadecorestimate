rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }

    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "golechhasanyam5@gmail.com" && request.auth.token.email_verified == true);
    }

    function hasRequiredFields(data, fields) {
       return data.keys().hasAll(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidEstimate(data) {
      return hasRequiredFields(data, ['version', 'estimateStatus', 'products', 'grandTotal', 'createdAt', 'updatedAt', 'createdBy']) &&
             (!('clientName' in data) || (data.clientName is string && data.clientName.size() < 100)) &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() < 20)) &&
             (!('siteAddress' in data) || (data.siteAddress is string && data.siteAddress.size() < 500)) &&
             (!('architectName' in data) || (data.architectName is string && data.architectName.size() < 100)) &&
             (!('assignee' in data) || (data.assignee is string && data.assignee.size() < 100)) &&
             (!('remarks' in data) || (data.remarks is string && data.remarks.size() < 2000)) &&
             data.version is int &&
             data.estimateStatus is string &&
             data.products is list &&
             data.products.size() < 100 &&
             data.grandTotal is number &&
             data.grandTotal >= 0 &&
             data.createdBy is string;
    }

    match /estimates/{estimateId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidEstimate(request.resource.data) && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuthenticated() && isValidEstimate(request.resource.data);
      allow delete: if isAuthenticated();
    }

    match /reminders/{reminderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.message is string && request.resource.data.message.size() < 500;
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated();
    }
  }
}
